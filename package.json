{
  "name": "patchline",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first internal automation learning project built around n8n, MAF, and modern AI system patterns.",
  "scripts": {
    "aspire:lint": "npm --prefix apphost run aspire:lint",
    "aspire:start": "aspire run",
    "aspire:build": "npm --prefix apphost run aspire:build",
    "aspire:dev": "npm --prefix apphost run aspire:dev",
    "dev": "pnpm run aspire:start",
    "build": "pnpm run aspire:build",
    "watch": "pnpm run aspire:dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm run aspire:lint && pnpm -r --if-present lint",
    "typecheck": "pnpm run aspire:build && pnpm -r --if-present typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "release-please": "^17.10.1",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.9.0"
}
