# Patchline local configuration

# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Postgres
POSTGRES_USER=patchline
POSTGRES_PASSWORD=patchline
POSTGRES_DB=patchline

# Ollama runs on the Windows host for GPU access.
OLLAMA_BASE_URL=http://host.containers.internal:11434

# GitHub sandbox repo target.
GITHUB_OWNER=
GITHUB_REPO=patchline-sandbox

# Telegram bot token is configured in n8n credentials, not committed here.

